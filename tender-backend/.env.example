# Application
APP_NAME=TenderIQ
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
API_VERSION=v1

# Database
DATABASE_URL=postgresql+asyncpg://tenderiq:tenderiq@localhost:5432/tenderiq
TEST_DATABASE_URL=postgresql+asyncpg://tenderiq:tenderiq@localhost:5432/tenderiq_test

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/bot/webhook

# Claude AI (Anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-20250514

# Payment: Click
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SERVICE_ID=your-click-service-id
CLICK_SECRET_KEY=your-click-secret-key

# Payment: Payme
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_SECRET_KEY=your-payme-secret-key

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@tenderiq.uz

# Scraper
SCRAPER_ENABLED=true
SCRAPER_MAX_RETRIES=3
SCRAPER_TIMEOUT=30

# ML
ML_MODEL_DIR=app/ml/saved_models
ML_RETRAIN_MIN_SAMPLES=100

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
